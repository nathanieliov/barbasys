NODE_ENV=production
PORT=3000

# Auth
JWT_SECRET=generate-with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_EXPIRES_IN=1d

# Email (Gmail App Password — NOT your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# SMS / Twilio (leave empty to disable SMS)
TWILIO_SID=
TWILIO_AUTH=
TWILIO_PHONE=

# WhatsApp Chatbot (leave OPENAI_API_KEY empty to disable chatbot)
SHOP_PHONE=+18095550123
OPENAI_API_KEY=
BYPASS_WEBHOOK_VERIFICATION=false

# Google Calendar (leave empty to disable calendar sync)
GCAL_CLIENT_ID=
GCAL_CLIENT_SECRET=
GCAL_REDIRECT_URI=https://your-domain.com/callback/google
GCAL_TOKEN_CIPHER_KEY=generate-with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
CALENDAR_WEBHOOK_URL=

# ngrok — each environment needs its own token
# Get tokens at: https://dashboard.ngrok.com/tunnels/agents
NGROK_AUTHTOKEN=
