# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Plain file path only — better-sqlite3 does NOT accept sqlite:// URIs.
# Leave empty to use the built-in default (backend/barbasys.db in dev).
DATABASE_URL=

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-chars
JWT_EXPIRES_IN=1d

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# ─── SMS / Twilio ─────────────────────────────────────────────────────────────
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH=your_twilio_auth_token
TWILIO_PHONE=+18095550123

# ─── WhatsApp Chatbot ─────────────────────────────────────────────────────────
SHOP_PHONE=+18095550123
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BYPASS_WEBHOOK_VERIFICATION=false

# ─── Google Calendar ──────────────────────────────────────────────────────────
GCAL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GCAL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxx
GCAL_REDIRECT_URI=http://localhost:3000/callback/google
GCAL_TOKEN_CIPHER_KEY=00112233445566778899aabbccddeeff
CALENDAR_WEBHOOK_URL=https://your-domain.com/webhooks/calendar
